    <event eventtype="8" enumb="64">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>if global.debugoverlay
{
    var _seconds = (fps_update_interval / room_speed);
    var _goodFPS = 2000;
    
    draw_set_font(font_menu);
    draw_set_halign(fa_left);
    draw_set_valign(fa_top);
    
    //TOTAL REAL AVERAGE//
    //TOTAL REAL AVERAGE//
    var _str = string_all(GAME_FPS_AVERAGE, " average fps over (", _seconds, " seconds)")
    var _scale = 2;
    var _colorAmount = clamp(GAME_FPS_AVERAGE/_goodFPS, 0, 1);
    var _color = merge_colour(c_red, c_lime, _colorAmount);
    var _alpha = 1;
    draw_text_transformed_colour(2, 25, _str, _scale, _scale, 0,
        _color, _color, _color, _color, _alpha);


    //10 PERCENT LOWS//
    //10 PERCENT LOWS//
    var _str = string_all(GAME_FPS_10PCT, " 10% lows")
    var _scale = 2;
    var _colorAmount = clamp(GAME_FPS_10PCT/_goodFPS, 0, 1);
    var _color = merge_colour(c_red, c_lime, _colorAmount);
    var _alpha = 1;
    draw_text_transformed_colour(2, 45, _str, _scale, _scale, 0,
        _color, _color, _color, _color, _alpha);
        
        
    //////////////////////////////////////
    //DEBUG DEV REMOVE LATER LAG SIMULATOR
    //////////////////////////////////////
    if keyboard_check(vk_lcontrol)
    {
        if keyboard_check_pressed(vk_lcontrol)
        {
            _lagSwitchDefault   = 40000;
            _lagSwitchAmount    = _lagSwitchDefault;
        }
    
        var _lagIncrement = 10000;
        if mouse_wheel_up() {_lagSwitchAmount += _lagIncrement;}
        if mouse_wheel_down() {_lagSwitchAmount -= _lagIncrement;}
        _lagSwitchAmount = max(_lagSwitchAmount, 0);
    
        var _i, _max;
        _max = _lagSwitchAmount; // Increase this for more lag
        for (_i = 0; _i &lt; _max; _i++) {
            // Just loop to waste time
            var _temp = sqrt(_i); // Do something meaningless
        }
        
        var _line1          = "DEBUG LAG SWITCH WHILE HOLDING LEFT CONTROL!! ";
        var _str            = string_all(_line1, percent_whole(_lagSwitchAmount, 0, _lagSwitchDefault), "%");
        var _scale          = 3;
        var _color          = iif((current_time div 250)%2, c_red, c_maroon);
        var _color2         = iif((current_time div 250)%2, c_red, c_maroon);
        var _alpha          = 1;
        draw_text_transformed_colour(2, 65, _str, _scale, _scale, 0,
            _color, _color, _color2, _color2, _alpha);
    }
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
