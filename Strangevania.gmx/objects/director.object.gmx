        <arguments>
          <argument>
            <kind>1</kind>
            <string>/// toggle debug overlay
global.debugoverlay = !global.debugoverlay;
show_debug_overlay(global.debugoverlay)
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="10" enumb="116">
      <action>
        <libid>1</libid>
