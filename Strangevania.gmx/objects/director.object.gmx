fps_timer = 0;
fps_average = 0;
fps_10pct_low = 0;

saveBackupPrefix    = "backups/saveBACKUP";
saveBackupSuffix    = ".dat";
saveBackupMax       = 10;
savemap  = undefined; //Leave this as undefined
savename = "save0.dat"

loadbarx = 4;
loadbary = 180-8;
loadbarw = vieww-loadbarx-64;
loadbarh = 2;
